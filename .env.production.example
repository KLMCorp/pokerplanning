# =============================================================================
# Poker Planning - Configuration Production
# =============================================================================
# Copiez ce fichier en .env pour la production

# Application
APP_NAME=Poker Planning
APP_URL=https://poker.example.com
PORT=3001

# Socket.IO (côté client)
NEXT_PUBLIC_SOCKET_URL=https://poker.example.com

# SMTP - Configurez votre serveur SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASSWORD=votre-mot-de-passe
SMTP_FROM=noreply@example.com
