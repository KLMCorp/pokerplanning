# =============================================================================
# Poker Planning - Configuration
# =============================================================================
# Copiez ce fichier en .env et adaptez les valeurs

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Nom de l'application (affiché dans les emails)
APP_NAME=Poker Planning

# URL publique de l'application (sans slash final)
APP_URL=https://poker.example.com

# Port du serveur Socket.IO (backend)
PORT=3001

# Origines CORS autorisées (séparées par des virgules)
# Par défaut, utilise APP_URL + localhost
# CORS_ORIGINS=https://poker.example.com,http://localhost:3000

# -----------------------------------------------------------------------------
# Socket.IO (côté client)
# -----------------------------------------------------------------------------
# URL du serveur Socket.IO pour le client Next.js
# En production avec le même domaine, utilisez le même que APP_URL
NEXT_PUBLIC_SOCKET_URL=https://poker.example.com

# -----------------------------------------------------------------------------
# SMTP - Configuration email
# -----------------------------------------------------------------------------
# Hôte du serveur SMTP
SMTP_HOST=smtp.example.com

# Port SMTP (587 pour TLS, 465 pour SSL, 25 pour non-sécurisé)
SMTP_PORT=587

# Connexion sécurisée (true pour SSL/465, false pour TLS/587 avec STARTTLS)
SMTP_SECURE=false

# Identifiant SMTP
SMTP_USER=noreply@example.com

# Mot de passe SMTP
SMTP_PASSWORD=your-smtp-password

# Adresse email d'expédition
SMTP_FROM=noreply@example.com

# -----------------------------------------------------------------------------
# Chemins des ressources (optionnel)
# -----------------------------------------------------------------------------
# Chemin de base pour les images de cartes
# Par défaut: /images/cartes
# CARDS_PATH=/images/cartes
# NEXT_PUBLIC_CARDS_PATH=/images/cartes

# Répertoire des données (base SQLite)
# Par défaut: ./data
# DATA_DIR=/app/data

# -----------------------------------------------------------------------------
# Limites (optionnel)
# -----------------------------------------------------------------------------
# Taille maximale des uploads en Mo (par défaut: 5)
# MAX_UPLOAD_SIZE_MB=5

# Nombre maximum de participants par room (0 = illimité)
# MAX_PARTICIPANTS_PER_ROOM=0

# Autoriser les uploads d'images (avatar, cartes personnalisées, fond de table)
# Par défaut: true. Mettre à false pour désactiver tous les uploads d'images
# ALLOW_UPLOADS=true

# -----------------------------------------------------------------------------
# Administration
# -----------------------------------------------------------------------------
# Email du super administrateur (seul compte pouvant accéder à /admin)
# Si non défini, la page admin est désactivée
# ADMIN_EMAIL=admin@example.com

# Chemin personnalisé pour la page admin (optionnel, côté serveur uniquement)
# Si défini, /admin sera bloqué et seul ce chemin donnera accès à la page admin
# Exemple: /secret-dashboard-42
# ADMIN_SECRET_PATH=/secret-dashboard-42

# -----------------------------------------------------------------------------
# TTL des rooms
# -----------------------------------------------------------------------------
# Durée de vie maximale des rooms en minutes (par défaut: 180 = 3 heures)
# Les utilisateurs peuvent configurer un TTL inférieur dans leur compte
ROOM_TTL_MINUTES=180

# -----------------------------------------------------------------------------
# Node.js (optionnel)
# -----------------------------------------------------------------------------
# Mode de l'application
# NODE_ENV=production
