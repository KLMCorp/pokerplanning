# =============================================================================
# Poker Planning - Configuration Nginx (Reverse Proxy)
# =============================================================================
# Exemple de configuration pour nginx comme reverse proxy
# Adaptez selon votre configuration SSL/domaine

upstream poker_next {
    server 127.0.0.1:3000;
}

upstream poker_socket {
    server 127.0.0.1:3001;
}

server {
    listen 80;
    server_name poker.example.com;

    # Redirection HTTPS
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name poker.example.com;

    # SSL - Adaptez selon votre configuration
    ssl_certificate /etc/letsencrypt/live/poker.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/poker.example.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;

    # Logs
    access_log /var/log/nginx/poker-planning.access.log;
    error_log /var/log/nginx/poker-planning.error.log;

    # Taille maximale des uploads (avatars, images de cartes)
    client_max_body_size 10M;

    # Socket.IO - WebSocket support
    location /socket.io/ {
        proxy_pass http://poker_socket;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
        proxy_send_timeout 86400;
    }

    # Health check du serveur Socket.IO
    location /health {
        proxy_pass http://poker_socket;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    # Application Next.js
    location / {
        proxy_pass http://poker_next;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # Cache pour les assets statiques
    location /_next/static/ {
        proxy_pass http://poker_next;
        proxy_cache_valid 200 365d;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    location /images/ {
        proxy_pass http://poker_next;
        proxy_cache_valid 200 7d;
        add_header Cache-Control "public, max-age=604800";
    }

    location /uploads/ {
        proxy_pass http://poker_socket;
        proxy_cache_valid 200 1d;
        add_header Cache-Control "public, max-age=86400";
    }
}
